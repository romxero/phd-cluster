[Unit]
Description=Gitea (Git with a cup of tea)
After=syslog.target
After=network.target
Requires=network.target

[Service]
RestartSec=2s
Type=simple
User={{ GITEA_USER }}
Group={{ GITEA_GROUP }}
WorkingDirectory={{ GITEA_PREFIX_DIR }}
ExecStart={{ GITEA_PREFIX_DIR }}/bin/gitea web --port {{ GITEA_WEB_SERVING_PORT }} --work-path {{ GITEA_PREFIX_DIR }}
Restart=always
Environment=USER={{ GITEA_USER }} HOME={{ GITEA_PREFIX_DIR }}

[Install]
WantedBy=multi-user.target